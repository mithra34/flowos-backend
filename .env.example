# ─── Database (Hostinger MySQL) ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_hostinger_db_user
DB_PASSWORD=your_hostinger_db_password
DB_NAME=flowos

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── CORS — your frontend domain on Hostinger ─────────────────────────────────
ALLOWED_ORIGIN=https://yourdomain.com
